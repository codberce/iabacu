# Public URL of this installation. Used for canonical links, sitemaps and
# social metadata. Keep localhost for local development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional AI grading and rubric chat. Any OpenAI-compatible chat-completions
# endpoint is supported; Anthropic-compatible `/messages` endpoints also work.
# The API key may stay empty for a local provider that does not require one.
AI_PROVIDER_API_URL=
AI_PROVIDER_MODEL=
AI_PROVIDER_API_KEY=

# Optional chat-specific overrides. They fall back to the values above.
AI_PROVIDER_CHAT_API_URL=
AI_PROVIDER_CHAT_MODEL=
